{
  "compilerOptions": {
    "target": "es2023",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["es2023", "dom"],
    "types": ["node"],
    "outDir": "../dist-server",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "./**/*.ts",
    "../src/types/**/*.ts",
    "../src/utils/**/*.ts",
    "../src/shared/mask.ts",
    "../src/shared/parse.ts",
    "../src/shared/types.ts",
    "../src/shared/globals-factory.ts",
    "../src/shared/executor-core.ts",
    "../src/shared/scheduler-base.ts",
    "../src/shared/blocked-globals.ts",
    "../src/shared/strip-constructors.ts",
    "../src/crypto/secrets.ts"
  ],
  "exclude": ["../node_modules", "./**/*.test.ts", "../src/**/*.test.ts"]
}
